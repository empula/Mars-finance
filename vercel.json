{
    "version": 2,
    "functions": {
        "api/market.js": { "maxDuration": 10 },
        "api/chat.js": { "maxDuration": 30 },
        "api/whale.js": { "maxDuration": 10 },
        "api/news.js": { "maxDuration": 10 }
    },
    "routes": [
        { "src": "/api/market", "dest": "/api/market.js" },
        { "src": "/api/chat", "dest": "/api/chat.js" },
        { "src": "/api/whale", "dest": "/api/whale.js" },
        { "src": "/api/news", "dest": "/api/news.js" },
        { "src": "/sitemap.xml", "dest": "/sitemap.xml" },
        { "src": "/(.*)", "dest": "/index.html" }
    ]
}
